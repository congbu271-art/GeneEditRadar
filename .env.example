# Optional in demo mode. Required only when you want persisted subscriptions
# and Netlify literature jobs. Use an external Postgres database from Neon,
# Supabase, Railway, or another managed database provider.
DATABASE_URL="postgresql://user:password@host:5432/geneeditradar?sslmode=require"

# ---------------------------------------------------------------------------
# LLM 智能分析（可选）。留空 => 网站全程使用规则引擎，仍可正常运行。
# 配置后，关键词模式的领域综述与文献模式的衍生课题改由大模型生成。
# 采用 OpenAI 兼容的 Chat Completions 接口，可切换至 DeepSeek / OpenAI / 通义 / 智谱 / Kimi 等。
# ---------------------------------------------------------------------------
# API Key（留空则不启用 LLM）。也兼容旧的 OPENAI_API_KEY。
LLM_API_KEY=""
# 接口地址，默认 DeepSeek。OpenAI 用 https://api.openai.com/v1
LLM_BASE_URL="https://api.deepseek.com/v1"
# 模型名，默认 deepseek-chat。OpenAI 可用 gpt-4o-mini 等。
LLM_MODEL="deepseek-chat"

# 向后兼容：旧变量仍被识别（作为 LLM_API_KEY / LLM_MODEL 的回退）。
OPENAI_API_KEY=""
OPENAI_EXTRACTION_MODEL="gpt-4o-mini"

# ---------------------------------------------------------------------------
# 邮件 digest（后续启用真实发送时使用）。当前 send-digest scheduled function
# 只记录投递去重状态，不会发送邮件。
# ---------------------------------------------------------------------------
RESEND_API_KEY=""
SENDGRID_API_KEY=""

# ---------------------------------------------------------------------------
# RSS / TOC feed 补充来源（可选）。默认已包含 Nature Biotechnology /
# Nature Methods / Nature Genetics 的 AOP feeds。这里可用逗号或换行补充
# 其他期刊 RSS URL。
# ---------------------------------------------------------------------------
LITERATURE_RSS_FEEDS=""

# ---------------------------------------------------------------------------
# 语义检索 / RAG（可选）。需要同时配置 DATABASE_URL 与 LLM_API_KEY。
# 仅在两者都存在时，/api/search/semantic 与 /papers 页的语义检索才激活。
# ---------------------------------------------------------------------------

# Unpaywall OA 查询用邮箱（可选，用于获取开放获取全文链接）
UNPAYWALL_EMAIL=""

# Embedding 接口地址（默认 OpenAI）。DeepSeek 暂无 Embedding 接口。
LLM_EMBEDDING_BASE_URL="https://api.openai.com/v1"
# Embedding 模型名（默认 text-embedding-3-small）
LLM_EMBEDDING_MODEL="text-embedding-3-small"

# ---------------------------------------------------------------------------
# 站点 URL（可选）。用于生成 sitemap、robots、OG 链接。
# 部署时设为你的实际域名。
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://geneeditradar.vercel.app"
