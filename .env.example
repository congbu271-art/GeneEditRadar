# Optional in demo mode. Local SQLite is only needed when you want Prisma-backed development.
DATABASE_URL="file:./dev.db"

# ---------------------------------------------------------------------------
# LLM 智能分析（可选）。留空 => 网站全程使用规则引擎，仍可正常运行。
# 配置后，关键词模式的领域综述与文献模式的衍生课题改由大模型生成。
# 采用 OpenAI 兼容的 Chat Completions 接口，可切换至 DeepSeek / OpenAI / 通义 / 智谱 / Kimi 等。
# ---------------------------------------------------------------------------
# API Key（留空则不启用 LLM）。也兼容旧的 OPENAI_API_KEY。
LLM_API_KEY=""
# 接口地址，默认 DeepSeek。OpenAI 用 https://api.openai.com/v1
LLM_BASE_URL="https://api.deepseek.com/v1"
# 模型名，默认 deepseek-chat。OpenAI 可用 gpt-4o-mini 等。
LLM_MODEL="deepseek-chat"

# 向后兼容：旧变量仍被识别（作为 LLM_API_KEY / LLM_MODEL 的回退）。
OPENAI_API_KEY=""
OPENAI_EXTRACTION_MODEL="gpt-4o-mini"
